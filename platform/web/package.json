{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "predev": "node scripts/generate-firebase-messaging-sw.mjs",
    "dev": "vite",
    "prebuild": "node scripts/generate-firebase-messaging-sw.mjs",
    "build": "vite build",
    "prebuild:mobile": "node scripts/generate-firebase-messaging-sw.mjs",
    "build:mobile": "vite build --mode capacitor",
    "android:clean-web-assets": "node -e \"const fs=require('fs');['dist','../android/app/src/main/assets/public'].forEach((d)=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "android:icons": "node scripts/prepare-capacitor-assets.mjs && npx @capacitor/assets generate --android --iconBackgroundColor \"#0f766e\" --iconBackgroundColorDark \"#083344\" --splashBackgroundColor \"#0f766e\" --splashBackgroundColorDark \"#083344\"",
    "web:icons": "node scripts/prepare-capacitor-assets.mjs && npx @capacitor/assets generate --pwa --iconBackgroundColor \"#0f766e\" --iconBackgroundColorDark \"#083344\" --splashBackgroundColor \"#0f766e\" --splashBackgroundColorDark \"#083344\" --pwaManifestPath public/manifest.webmanifest",
    "icons:all": "npm run web:icons && npm run android:icons",
    "android:sync": "npm run build:mobile && npx cap sync android",
    "android:sync:clean": "npm run android:clean-web-assets && npm run build:mobile && npx cap sync android",
    "android:apk:debug": "npm run android:sync && cd ../android && gradlew.bat assembleDebug",
    "android:apk:debug:clean": "npm run android:sync:clean && cd ../android && gradlew.bat assembleDebug",
    "android:apk:debug:unix": "npm run android:sync && cd ../android && ./gradlew assembleDebug",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.28.6",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@firebase/storage": "^0.14.0",
    "@sentry/react": "^8.55.1",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-virtual": "^3.13.23",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "exceljs": "^4.1.1",
    "firebase": "^11.10.0",
    "html2pdf.js": "^0.14.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-image-crop": "^11.0.10",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^0.19.8"
  }
}
