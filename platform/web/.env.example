# Supabase Configuration
# Replace with your actual Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Replace with your actual Supabase anon public key
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Replace with your actual Supabase service role key (keep secure)
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Application Configuration
VITE_APP_NAME=Neighbourhood Watch
VITE_APP_VERSION=1.0.0

# API Configuration (if using external APIs)
VITE_API_BASE_URL=https://your-api-url.com

# Optional: base URL for password-reset emails (default: current origin). Must be listed under
# Supabase → Authentication → URL Configuration → Redirect URLs (e.g. https://your-app.vercel.app/update-password).
# VITE_AUTH_REDIRECT_ORIGIN=https://your-app.vercel.app

# Optional: Google Analytics
# VITE_GOOGLE_ANALYTICS_ID=your_ga_measurement_id

# Shown on Profile for OAuth-only users (account deletion by email). Also use in your privacy policy.
# VITE_PRIVACY_CONTACT_EMAIL=privacy@yourdomain.example

# Optional: Sentry for error tracking (set on Vercel for production)
# VITE_SENTRY_DSN=your_sentry_dsn_here

# Firebase (Web / FCM) — from Firebase Console → Project settings → Your apps → Web app
# npm run dev / npm run build runs scripts/generate-firebase-messaging-sw.mjs, which writes
# public/firebase-messaging-sw.js (gitignored). Set these on Vercel too so deploys get FCM.
# Capacitor Android: download google-services.json into web/android/app/ (gitignored); see
# android/app/google-services.json.example.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — Android app id (native/Capacitor only; not used by Vite bundle)
# VITE_FIREBASE_ANDROID_APP_ID=1:xxxx:android:xxxx
# Cloud Messaging → Web Push certificates → Key pair (VAPID)
# VITE_FCM_VAPID_KEY=

# Supabase Edge Function location-cleanup: set CRON_SECRET in Dashboard → Edge Functions → Secrets,
# then send header x-cron-secret on scheduled invocations (not a Vite var).

# Optional: Feature flags
# VITE_ENABLE_FEATURE_X=true
# VITE_ENABLE_FEATURE_Y=false

# Development-specific variables (only used in development)
# VITE_MOCK_API=false
# VITE_DEBUG_MODE=true